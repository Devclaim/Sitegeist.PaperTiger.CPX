from "./FormProps.cpx" import { FormProps }

export component Form {
  form: FormProps
  error: slot
  content: slot

  render <form
    id={form.id}
    class="papertiger-form__element"
    action={form.action}
    method={form.method}
    enctype="multipart/form-data"
  >
    {error}
    {content}
  </form>
}
