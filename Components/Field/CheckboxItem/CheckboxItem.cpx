from "./CheckboxItemProps.cpx" import { CheckboxItemProps }

export component CheckboxItem {
  option: CheckboxItemProps

  render <label class="papertiger-checkbox-item">
    <input
      type="checkbox"
      name={option.name}
      value={option.value}
      checked={option.isChecked}
      required={option.isRequired}
      class="papertiger-checkbox-item__input"
      data-fieldtype="input"
      data-custom-error-message={option.customErrorMessageEnabled ? option.customErrorMessage : null}
      oninvalid="this.setCustomValidity(this.dataset.customErrorMessage || '')"
      oninput="this.setCustomValidity('')"
    />
    <span class="papertiger-checkbox-item__label">{option.label}</span>
  </label>
}
