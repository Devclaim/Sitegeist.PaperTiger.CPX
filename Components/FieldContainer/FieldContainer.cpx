from "./FieldContainerProps.cpx" import { FieldContainerProps }

export component FieldContainer {
  fieldContainer: FieldContainerProps
  label: slot
  content: slot
  error: slot

  render <div
    id={fieldContainer.id}
    class={fieldContainer.hasErrors ? "papertiger-field papertiger-field--invalid showInvalid" : "papertiger-field"}
    data-form-field
  >
    {label}
    {content}
    {error}
  </div>
}
