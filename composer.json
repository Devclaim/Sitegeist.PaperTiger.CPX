{
    "description": "Editable form nodetypes for Neos CMS with CPX-oriented rendering fallbacks",
    "type": "neos-plugin",
    "name": "sitegeist/papertiger-cpx",
    "license": "GPL-3.0+",
    "require": {
        "php": ">=8.2",
        "neos/neos": "^9.0",
        "neos/neos-ui": "^9.1",
        "packagefactory/neos-component-engine": "1.0.0-alpha3",
        "sitegeist/inspectorgadget": "^3.0",
        "sitegeist/schemeonyou": "^2.1.0"
    },
    "autoload": {
        "psr-4": {
            "Sitegeist\\PaperTiger\\CPX\\": "Classes/",
            "Sitegeist\\PaperTiger\\CPX\\Components\\": "Components/",
            "Sitegeist\\PaperTiger\\CPX\\NodeTypes\\": "NodeTypes/"
        }
    },
    "scripts": {
        "build:cpx": "../../../flow components:build 'Sitegeist.PaperTiger.CPX'"
    },
    "extra": {
        "neos": {
            "package-key": "Sitegeist.PaperTiger.CPX"
        }
    },
    "config": {
        "allow-plugins": {
            "neos/composer-plugin": true
        }
    }
}
